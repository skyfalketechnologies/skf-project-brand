# Django
SECRET_KEY=generate-a-long-random-string-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-service.onrender.com

# Database (Render PostgreSQL — paste Internal Database URL from Render dashboard)
DATABASE_URL=postgres://user:password@host:5432/dbname

# CORS — your frontend URL(s), comma-separated
CORS_ORIGINS=http://localhost:5173,https://your-site.netlify.app

# CSRF — same origins as CORS (https required in production)
CSRF_TRUSTED_ORIGINS=http://localhost:5173,https://your-site.netlify.app

# Optional: create/update superuser on deploy (set a strong password)
DJANGO_SUPERUSER_PASSWORD=admin123
DJANGO_SUPERUSER_EMAIL=admin@silvoralabs.local

# Optional: AI chat widget (falls back to static replies if unset)
GEMINI_API_KEY=

# Optional: MongoDB for project sync (SQLite/Postgres still works without this)
MONGODB_URI=
